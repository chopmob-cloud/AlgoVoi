# Owner wallet (human — never give this to the agent)
OWNER_MNEMONIC=word1 word2 word3 ... word25

# Agent key (AI agent holds this — limited by the contract)
AGENT_MNEMONIC=word1 word2 word3 ... word25
AGENT_ADDRESS=ABCDEF...

# Deployed app IDs (filled in by deploy.py → deployments.json)
ALGORAND_APP_ID=
VOI_APP_ID=

# Spending limits (micro-units: 1 ALGO = 1000000)
MAX_PER_TXN=1000000          # 1 ALGO/VOI per payment
DAILY_CAP=10000000           # 10 ALGO/VOI per day
MAX_ASA_PER_TXN=1000000      # 1 USDC/aUSDC per pay_asa()
ALLOWLIST_ENABLED=0          # 0=open, 1=whitelist enforced

# Seed the vault on deploy (optional)
INITIAL_FUND_MICROALGOS=5000000   # 5 ALGO/VOI
